# Copy to secrets.toml in this same folder (gitignored).
# Streamlit loads this when you run: streamlit run demo/app.py
#
# Or paste the same keys into Streamlit Community Cloud → Settings → Secrets.

SEARCH_API_URL = "https://YOUR_API_ID.execute-api.us-east-1.amazonaws.com"
COGNITO_CLIENT_ID = "your-cognito-app-client-id"
AWS_REGION = "us-east-1"

# boto3 needs credentials to sign Cognito InitiateAuth requests.
AWS_ACCESS_KEY_ID = "AKIA..."
AWS_SECRET_ACCESS_KEY = "..."
